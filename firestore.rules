rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'careers.growthexpress@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Product persistence rules
    match /products/{productId} {
      allow read: if true; // Public can see products
      allow create, update, delete: if isAdmin();
      
      function isValidProduct(data) {
        return data.name is string && data.name.size() > 0 &&
               data.price is number && data.price >= 0 &&
               data.category is string;
      }

      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
    }

    // Settings rules
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders rules
    match /orders/{orderId} {
      allow create: if isValidOrder(incoming());
      allow read: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      allow update, delete: if isAdmin();
      
      function isValidOrder(data) {
        return data.total is number && data.total >= 0 &&
               data.status in ['pending', 'confirmed', 'processing', 'shipped', 'delivered', 'cancelled'] &&
               data.customer is map &&
               data.customer.firstName is string &&
               data.customer.firstName.size() > 0 &&
               data.customer.phone is string &&
               data.customer.phone.size() >= 10 &&
               data.customer.address is string &&
               data.customer.paymentMethod in ['cod', 'bkash', 'nagad', 'rocket'] &&
               (data.customer.paymentMethod == 'cod' || (data.customer.transactionId is string && data.customer.transactionId.size() > 0)) &&
               data.items is list &&
               data.items.size() > 0;
      }
    }

    // Extended Users profiles
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && request.auth.uid == userId;
      
      function isValidUser(data) {
        return (data.phone is string && data.phone.size() <= 20) &&
               (data.address is string && data.address.size() <= 500) &&
               (data.city is string && data.city.size() <= 100) &&
               (data.area is string && data.area.size() <= 100) &&
               (data.bio is string && data.bio.size() <= 1000);
      }

      allow create, update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
    }

    // Admin authorization rules
    match /admins/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin(); // Only existing admins can add new admins
    }
  }
}
